{
  "name": "@naughtyjs/proberesponder",
  "version": "0.1.1",
  "description": "Probe responder utilities for startup/readiness/liveness in Node.js and TypeScript",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/naughtyjs/proberesponder.git"
  },
  "homepage": "https://github.com/naughtyjs/proberesponder",
  "bugs": {
    "url": "https://github.com/naughtyjs/proberesponder/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./http": {
      "import": "./dist/extensions/http/index.js",
      "types": "./dist/extensions/http/index.d.ts"
    },
    "./depprober": {
      "import": "./dist/extensions/depprober/index.js",
      "types": "./dist/extensions/depprober/index.d.ts"
    }
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "packageManager": "npm@10.9.4",
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"examples/**/*.ts\" vitest.config.ts tsup.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --coverage.reportsDirectory=coverage --coverage.reporter=json-summary --coverage.reporter=text && node scripts/check-coverage.mjs",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.30",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "typescript-eslint": "^8.33.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.7"
  }
}
